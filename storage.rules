rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function maxSize() {
      return 1024 * 1024 * 1024; // 1GB
    }

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isWorkshopStudent() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'workshopStudent'
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.workshopAccess == true;
    }

    match /printUploads/{fileName} {
      allow read: if true;
      allow create: if request.resource.size <= maxSize();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /studentWorks/{fileName} {
      allow read: if true;
      allow create: if request.resource.size <= maxSize();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /workshopMaterials/{fileName} {
      allow read: if isAdmin() || isWorkshopStudent();
      allow create, update, delete: if isAdmin() && request.resource.size <= maxSize();
    }

    match /workshopSubmissions/{uid}/{fileName} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid && request.resource.size <= maxSize();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
